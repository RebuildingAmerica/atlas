#!/bin/bash
set -euo pipefail

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

COMMIT_MSG_FILE="$1"
COMMIT_HEADER=$(head -n 1 "$COMMIT_MSG_FILE")

# Conventional Commits pattern
# Format: type(scope)?: message
# Scopes are optional, but when present they must use an approved repo term.
# Descriptions must start with sentence case.
PATTERN='^(feat|fix|docs|chore|refactor)(\((api|app|pipeline|scout|docs|dx)\))?!?: [A-Z0-9].+'

if ! echo "$COMMIT_HEADER" | grep -qE "$PATTERN"; then
    echo -e "\n${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}✗ Commit message does not follow Conventional Commits${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"

    echo "Your message: ${YELLOW}$COMMIT_HEADER${NC}"
    echo ""
    echo "Format: ${BLUE}type(scope)?: message${NC}"
    echo ""
    echo "Valid types:"
    echo "  - ${BLUE}feat${NC}:     Consumer-facing capability added to the product"
    echo "  - ${BLUE}fix${NC}:      Consumer-facing bug fix in shipped behavior"
    echo "  - ${BLUE}docs${NC}:     Documentation-only changes"
    echo "  - ${BLUE}chore${NC}:    Documentation, tests, tooling, dependencies, or internal maintenance"
    echo "  - ${BLUE}refactor${NC}: Internal code reshaping with no behavior change"
    echo ""
    echo "Valid scopes (optional):"
    echo "  - ${BLUE}api${NC}:         Python/FastAPI application code"
    echo "  - ${BLUE}app${NC}:         React/TanStack Start application code"
    echo "  - ${BLUE}pipeline${NC}:    Discovery pipeline
  - ${BLUE}scout${NC}:       Atlas Scout autonomous discovery package"
    echo "  - ${BLUE}docs${NC}:        Documentation files"
    echo "  - ${BLUE}dx${NC}:          Developer experience, tooling, deployment, CI/CD"
    echo "  Use no scope for broad or cross-cutting changes."
    echo ""
    echo "Examples:"
    echo "  ${BLUE}feat(app): Add browse experience for issue areas${NC}"
    echo "  ${BLUE}fix(api): Return correct pagination metadata${NC}"
    echo "  ${BLUE}docs: Clarify local development workflow${NC}"
    echo "  ${BLUE}chore(dx): Improve setup guidance for junior developers${NC}"
    echo "  ${BLUE}refactor(pipeline): Simplify deduplication helpers${NC}"
    echo ""

    exit 1
fi

exit 0
