#!/bin/bash
set -euo pipefail

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Conventional Commits pattern
# Format: type(scope)?: message
# where type is one of: feat, fix, docs, refactor, test, chore, perf, ci, build, style
PATTERN='^(feat|fix|docs|refactor|test|chore|perf|ci|build|style)(\([a-z0-9-]+\))?!?: .+'

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo -e "\n${RED}‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ${NC}"
    echo -e "${RED}‚úó Commit message does not follow Conventional Commits${NC}"
    echo -e "${RED}‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ‚îÅ${NC}\n"

    echo "Your message: ${YELLOW}$COMMIT_MSG${NC}"
    echo ""
    echo "Format: ${BLUE}type(scope)?: message${NC}"
    echo ""
    echo "Valid types:"
    echo "  - ${BLUE}feat${NC}:     A new feature"
    echo "  - ${BLUE}fix${NC}:      A bug fix"
    echo "  - ${BLUE}docs${NC}:     Documentation only"
    echo "  - ${BLUE}refactor${NC}: Code refactoring (no feature change)"
    echo "  - ${BLUE}test${NC}:     Adding or updating tests"
    echo "  - ${BLUE}chore${NC}:    Dependency, tooling, or config changes"
    echo "  - ${BLUE}perf${NC}:     Performance improvements"
    echo "  - ${BLUE}ci${NC}:       CI/CD config changes"
    echo "  - ${BLUE}build${NC}:    Build process or deps changes"
    echo "  - ${BLUE}style${NC}:    Code style changes (formatting, etc.)"
    echo ""
    echo "Scope (optional): The area of code affected (e.g., auth, database)"
    echo ""
    echo "Examples:"
    echo "  ${BLUE}feat: Add user authentication${NC}"
    echo "  ${BLUE}fix(auth): Handle expired tokens correctly${NC}"
    echo "  ${BLUE}docs: Update README with setup instructions${NC}"
    echo "  ${BLUE}refactor(api): Simplify error handling${NC}"
    echo "  ${BLUE}test(integration): Add E2E tests for checkout flow${NC}"
    echo ""

    exit 1
fi

exit 0
