#!/bin/bash
set -euo pipefail

# Color codes (disabled when not in TTY to prevent escape sequence leakage)
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  NC='\033[0m'
else
  RED=''
  GREEN=''
  YELLOW=''
  BLUE=''
  NC=''
fi

# Helper functions
print_header() {
    echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_info() {
    echo -e "${YELLOW}ℹ $1${NC}"
}

ROOT_DIR="$(git rev-parse --show-toplevel)"
API_DIR="$ROOT_DIR/api"
APP_DIR="$ROOT_DIR/app"

print_header "Pre-push Quality Gates"

# Early exit if there's nothing to push
refs_content=$(cat)
if [ -z "$refs_content" ]; then
    print_info "No refs to push, skipping quality gates"
    exit 0
fi

FAILED=0

# 1. Check if working directory is clean
print_info "Checking working directory status..."
if [ -n "$(git status --porcelain)" ]; then
    print_error "Working directory has uncommitted changes"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Commit or stash your changes before pushing"
    echo "  Run: git status"
    echo ""
    FAILED=1
else
    print_success "Working directory is clean"
fi

# 2. Run full typecheck (mypy + tsc)
print_info "Running full typecheck suite..."

print_info "  API: mypy..."
if ! (cd "$API_DIR" && uv run mypy atlas > /dev/null 2>&1); then
    print_error "MyPy type check failed"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Run: cd api && uv run mypy atlas"
    echo "  Fix type errors and commit"
    echo ""
    FAILED=1
else
    print_success "API types OK"
fi

print_info "  App: TypeScript..."
if ! (cd "$APP_DIR" && pnpm run typecheck > /dev/null 2>&1); then
    print_error "TypeScript check failed"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Run: cd app && pnpm run typecheck"
    echo "  Fix type errors and commit"
    echo ""
    FAILED=1
else
    print_success "App types OK"
fi

# 3. Run full test suite with coverage
print_info "Running full test suite..."

print_info "  API: pytest with coverage (minimum 90%)..."
if ! (cd "$API_DIR" && uv run pytest --cov=atlas --cov-fail-under=90 > /dev/null 2>&1); then
    print_error "API tests failed or coverage below 90%"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Run: cd api && uv run pytest --cov=atlas --cov-report=term-missing"
    echo "  Write tests for uncovered code"
    echo ""
    FAILED=1
else
    print_success "API tests passed with 90%+ coverage"
fi

print_info "  App: vitest with coverage (minimum 70%)..."
if ! (cd "$APP_DIR" && pnpm run test:coverage > /dev/null 2>&1); then
    print_error "App tests failed or coverage threshold not met"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Run: cd app && pnpm run test:coverage"
    echo "  Fix test failures or improve coverage and commit"
    echo ""
    FAILED=1
else
    print_success "App tests passed with 70%+ coverage"
fi

# Final result
if [ $FAILED -eq 0 ]; then
    print_header "All pre-push checks passed! Ready to push..."
    exit 0
else
    print_header "Push blocked: Fix the issues above and try again"
    exit 1
fi
