#!/bin/bash
set -euo pipefail

# Color codes (disabled when not in TTY to prevent escape sequence leakage)
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  NC='\033[0m'
else
  RED=''
  GREEN=''
  YELLOW=''
  BLUE=''
  NC=''
fi

# Helper functions
print_header() {
    echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_info() {
    echo -e "${YELLOW}ℹ $1${NC}"
}

ROOT_DIR="$(git rev-parse --show-toplevel)"

print_header "Pre-push Quality Gates"

# Early exit if there's nothing to push
refs_content=$(cat)
if [ -z "$refs_content" ]; then
    print_info "No refs to push, skipping quality gates"
    exit 0
fi

FAILED=0

# 1. Check if working directory is clean
print_info "Checking working directory status..."
if [ -n "$(git status --porcelain)" ]; then
    print_error "Working directory has uncommitted changes"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Commit or stash your changes before pushing"
    echo "  Run: git status"
    echo ""
    FAILED=1
else
    print_success "Working directory is clean"
fi

# 2. Run full quality suite via turbo (typecheck + lint + test for all packages)
if [ $FAILED -eq 0 ]; then
    print_info "Running full quality suite (turbo run typecheck lint test)..."
    if ! (cd "$ROOT_DIR" && TURBO_UI=0 pnpm run quality 2>&1); then
        print_error "Quality checks failed"
        echo ""
        echo -e "${YELLOW}HOW TO FIX:${NC}"
        echo "  Run: pnpm run quality"
        echo "  Fix any typecheck, lint, or test failures and commit"
        echo ""
        FAILED=1
    else
        print_success "All quality checks passed"
    fi
fi

# Final result
if [ $FAILED -eq 0 ]; then
    print_header "All pre-push checks passed! Ready to push..."
    exit 0
else
    print_header "Push blocked: Fix the issues above and try again"
    exit 1
fi
