#!/bin/bash
set -euo pipefail

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Helper functions
print_header() {
    echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_info() {
    echo -e "${YELLOW}ℹ $1${NC}"
}

print_header "Pre-push Quality Gates"

FAILED=0

# 1. Check if working directory is clean
print_info "Checking working directory status..."
if [ -n "$(git status --porcelain)" ]; then
    print_error "Working directory has uncommitted changes"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Commit or stash your changes before pushing"
    echo "  Run: git status"
    echo ""
    FAILED=1
else
    print_success "Working directory is clean"
fi

# 2. Run full typecheck (mypy + tsc)
print_info "Running full typecheck suite..."

print_info "  Backend: mypy..."
if ! cd backend && mypy atlas > /dev/null 2>&1; then
    print_error "MyPy type check failed"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Run: cd backend && mypy atlas"
    echo "  Fix type errors and commit"
    echo ""
    FAILED=1
else
    print_success "Backend types OK"
fi
cd - > /dev/null

print_info "  Frontend: TypeScript..."
if ! cd frontend && npm run typecheck > /dev/null 2>&1; then
    print_error "TypeScript check failed"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Run: cd frontend && npm run typecheck"
    echo "  Fix type errors and commit"
    echo ""
    FAILED=1
else
    print_success "Frontend types OK"
fi
cd - > /dev/null

# 3. Run full test suite with coverage
print_info "Running full test suite..."

print_info "  Backend: pytest with coverage (minimum 90%)..."
if ! cd backend && pytest --cov=atlas --cov-fail-under=90 > /dev/null 2>&1; then
    print_error "Backend tests failed or coverage below 90%"
    echo ""
    echo -e "${YELLOW}HOW TO FIX:${NC}"
    echo "  Run: cd backend && pytest --cov=atlas --cov-report=term-missing"
    echo "  Write tests for uncovered code"
    echo ""
    FAILED=1
else
    print_success "Backend tests passed with 90%+ coverage"
fi
cd - > /dev/null

print_info "  Frontend: npm test..."
if ! cd frontend && npm run test > /dev/null 2>&1; then
    print_info "Frontend tests not yet configured (skipping)"
else
    print_success "Frontend tests passed"
fi
cd - > /dev/null

# Final result
if [ $FAILED -eq 0 ]; then
    print_header "All pre-push checks passed! Ready to push..."
    exit 0
else
    print_header "Push blocked: Fix the issues above and try again"
    exit 1
fi
