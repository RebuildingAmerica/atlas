# Atlas API local environment

DATABASE_URL=sqlite:///atlas.db
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
SEARCH_API_KEY=
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
LOG_LEVEL=info
ENVIRONMENT=dev
HOST=0.0.0.0
PORT=8000
ENABLE_OPENAPI_SPEC=true
ENABLE_API_DOCS_UI=true

# Deployment mode. Leave unset (or empty) for the default multi-user dev
# stack — `pnpm dev` from the repo root runs that flow with auth, sign-up,
# and Stripe enabled. Set to "local" to run a single-user, auth-disabled
# local stack — `pnpm dev:local` exports this for you.
ATLAS_DEPLOY_MODE=

# Auth — required when ATLAS_DEPLOY_MODE is not "local".
# ATLAS_API_AUDIENCE is the OAuth audience claim the API accepts. It may be
# comma-separated when distinct values must be issued for the REST API and the
# MCP endpoint per RFC 8707.
# ATLAS_API_AUDIENCE=https://api.atlas.example.com
# ATLAS_PUBLIC_URL=https://atlas.example.com
# ATLAS_AUTH_INTERNAL_SECRET=
# ATLAS_AUTH_API_KEY_INTROSPECTION_URL=
# ATLAS_AUTH_MEMBERSHIP_URL=
