{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Atlas Docs",
  "basePath": "/docs",
  "favicon": "https://atlas.rebuildingus.org/favicon.ico",
  "appearance": {
    "default": "system"
  },
  "colors": {
    "primary": "#c2956a",
    "light": "#d4b896",
    "dark": "#a67b50"
  },
  "feedback": {
    "thumbsRating": true
  },
  "redirects": [
    {
      "source": "/product/overview",
      "destination": "/what-is-atlas"
    },
    {
      "source": "/introduction",
      "destination": "/what-is-atlas"
    },
    {
      "source": "/migration",
      "destination": "/what-is-atlas"
    },
    {
      "source": "/mcp",
      "destination": "/mcp/overview"
    },
    {
      "source": "/api-reference",
      "destination": "/api-reference/overview"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Why Atlas exists",
            "pages": ["what-is-atlas", "how-it-works", "taxonomy"]
          },
          {
            "group": "Use cases",
            "pages": [
              "use-cases/journalists",
              "use-cases/organizers",
              "use-cases/documentary",
              "use-cases/developers"
            ]
          },
          {
            "group": "Getting started",
            "pages": ["quickstart-learn", "quickstart-browse", "account/pricing"]
          },
          {
            "group": "Self-hosting",
            "pages": ["self-hosting/guide"]
          }
        ]
      },
      {
        "tab": "MCP & Agents",
        "groups": [
          {
            "group": "Get connected",
            "pages": [
              "mcp/overview",
              "mcp/registry",
              "mcp/claude-desktop",
              "mcp/claude-code",
              "mcp/vscode-copilot",
              "mcp/gemini",
              "mcp/codex",
              "mcp/copilot-cli",
              "mcp/other-clients",
              "mcp/client-id-metadata"
            ]
          },
          {
            "group": "Tools & permissions",
            "pages": ["mcp/tools", "mcp/scopes"]
          },
          {
            "group": "Troubleshoot",
            "pages": ["mcp/troubleshooting"]
          },
          {
            "group": "Tutorials",
            "pages": [
              "mcp/tutorials/research-city",
              "mcp/tutorials/agent-workflow"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi/atlas.openapi.json",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication",
              "api-reference/quickstart",
              "api-reference/typescript-sdk",
              "api-reference/rate-limits",
              "api-reference/errors"
            ]
          },
          {
            "group": "Resource guides",
            "pages": [
              "api-reference/guides/entities",
              "api-reference/guides/places",
              "api-reference/guides/taxonomy",
              "api-reference/guides/discovery",
              "api-reference/guides/sources-flags"
            ]
          },
          {
            "group": "Core endpoints",
            "pages": [
              "GET /health",
              {
                "group": "Discovery runs",
                "pages": [
                  "GET /api/discovery-runs",
                  "POST /api/discovery-runs",
                  "GET /api/discovery-runs/{run_id}"
                ]
              },
              {
                "group": "Domains and issue areas",
                "pages": [
                  "GET /api/domains",
                  "GET /api/domains/{domain_slug}",
                  "GET /api/issue-areas",
                  "GET /api/issue-areas/{issue_area_slug}"
                ]
              },
              {
                "group": "Places",
                "pages": [
                  "GET /api/places/{place_key}",
                  "GET /api/places/{place_key}/coverage",
                  "GET /api/places/{place_key}/entities",
                  "GET /api/places/{place_key}/issue-signals",
                  "GET /api/places/{place_key}/profile",
                  "GET /api/places/{place_key}/sources"
                ]
              },
              {
                "group": "Entities",
                "pages": [
                  "GET /api/entities",
                  "POST /api/entities",
                  "GET /api/entities/{entity_id}",
                  "PATCH /api/entities/{entity_id}",
                  "DELETE /api/entities/{entity_id}",
                  "GET /api/entities/{entity_id}/sources"
                ]
              },
              {
                "group": "Flags",
                "pages": [
                  "GET /api/entity-flags",
                  "POST /api/entity-flags",
                  "GET /api/source-flags",
                  "POST /api/source-flags"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Concepts",
            "pages": [
              "resources/data-model",
              "resources/trust",
              "resources/glossary"
            ]
          },
          {
            "group": "Help",
            "pages": ["resources/faq", "resources/troubleshooting"]
          },
          {
            "group": "Project",
            "pages": [
              "resources/changelog",
              "resources/contributing",
              "resources/open-source"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Repository",
          "href": "https://github.com/RebuildingAmerica/atlas",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Atlas",
        "href": "https://atlas.rebuildingus.org"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/RebuildingAmerica/atlas"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/RebuildingAmerica/atlas"
    }
  },
  "api": {
    "openapi": "openapi/atlas.openapi.json",
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "url": "full",
    "examples": {
      "languages": ["bash", "python", "javascript", "typescript"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  }
}
