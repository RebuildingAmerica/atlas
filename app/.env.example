# Example shape only. `make setup` writes the concrete local values to
# app/.env.local for host-based development.

# Deployment mode: "local" for local development, omit for hosted/production.
# Controls whether auth UI (sign-in, account, sign-out) is visible.
ATLAS_DEPLOY_MODE=local

ATLAS_PUBLIC_URL=replace-with-your-local-app-origin
# Mintlify deployment origin, for example https://your-subdomain.mintlify.dev
ATLAS_DOCS_URL=

# Vite dev server proxy target for non-auth API routes.
ATLAS_DEV_API_PROXY_TARGET=http://api.localhost:1355
# Server-side API target for SSR loaders and server functions.
ATLAS_SERVER_API_PROXY_TARGET=http://api.localhost:1355

ATLAS_AUTH_BASE_PATH=/api/auth
# Required when ATLAS_DEPLOY_MODE is not "local".
ATLAS_AUTH_INTERNAL_SECRET=replace-with-a-local-secret-if-you-enable-auth

# Comma-separated allowlist of SAML IdP issuer URLs (matched by origin).
# Required to register any workspace SAML provider; empty list denies all
# SAML registrations.
ATLAS_SAML_ALLOWED_ISSUERS=

# Optional PEM-encoded SP private key used to sign outbound SAML AuthnRequests.
# When set, new SAML registrations flip authnRequestsSigned: true.
ATLAS_SAML_SP_PRIVATE_KEY=
ATLAS_SAML_SP_PRIVATE_KEY_PASS=
ATLAS_EMAIL_PROVIDER=capture
ATLAS_EMAIL_FROM=replace-with-your-local-auth-from-address
ATLAS_EMAIL_CAPTURE_URL=replace-with-your-local-mail-capture-url
ATLAS_EMAIL_RESEND_API_KEY=

# Base64-encoded Ed25519 public key materialized into
# app/public/.well-known/mcp-registry-auth at build time so the MCP Registry
# can verify Atlas publisher identity. Required when running `pnpm build`
# (and recommended in dev so /.well-known/mcp-registry-auth resolves locally).
MCP_REGISTRY_AUTH_PUBKEY=

