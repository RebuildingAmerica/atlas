# Example shape only. `make setup` writes the concrete local values to
# app/.env.local for host-based development.

# Deployment mode: "local" for local development, omit for hosted/production.
# Controls whether auth UI (sign-in, account, sign-out) is visible.
ATLAS_DEPLOY_MODE=local

ATLAS_PUBLIC_URL=replace-with-your-local-app-origin

# Vite dev server proxy target for non-auth API routes.
ATLAS_DEV_API_PROXY_TARGET=http://api.localhost:1355

ATLAS_AUTH_BASE_PATH=/api/auth
# Required when ATLAS_DEPLOY_MODE is not "local".
ATLAS_AUTH_INTERNAL_SECRET=replace-with-a-local-secret-if-you-enable-auth
ATLAS_EMAIL_PROVIDER=capture
ATLAS_EMAIL_FROM=replace-with-your-local-auth-from-address
ATLAS_EMAIL_CAPTURE_URL=replace-with-your-local-mail-capture-url
ATLAS_EMAIL_RESEND_API_KEY=
