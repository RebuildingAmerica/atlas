# Example shape only. `make setup` writes the concrete local values to
# app/.env.e2e for end-to-end runs.
ATLAS_E2E_APP_URL=replace-with-your-local-e2e-app-origin
ATLAS_E2E_API_URL=replace-with-your-local-e2e-api-origin
ATLAS_E2E_AUTH_INTROSPECTION_URL=replace-with-your-local-auth-introspection-url
ATLAS_E2E_MAILBOX_URL=replace-with-your-local-mailbox-origin
