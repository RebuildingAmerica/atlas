{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "envMode": "strict",
  "globalDependencies": [
    "pnpm-workspace.yaml",
    "package.json",
    "pnpm-lock.yaml",
    "api/pyproject.toml",
    "api/uv.lock",
    ".env.example"
  ],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".output/**", "dist/**"],
      "env": ["ATLAS_DEPLOY_MODE", "ATLAS_PUBLIC_URL", "ATLAS_AUTH_BASE_PATH"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "package.json", "pyproject.toml", "uv.lock"],
      "env": ["ATLAS_DEPLOY_MODE"]
    },
    "lint": {
      "inputs": ["$TURBO_DEFAULT$", "eslint.config.js", ".eslintrc.*", "pyproject.toml", "ruff.toml"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "vitest.config.ts", "pytest.ini", "pyproject.toml", "uv.lock"],
      "env": [
        "DATABASE_URL",
        "ATLAS_DEPLOY_MODE",
        "ATLAS_AUTH_INTERNAL_SECRET",
        "ENVIRONMENT",
        "LOG_LEVEL",
        "ATLAS_PUBLIC_URL"
      ]
    },
    "quality": {
      "dependsOn": ["typecheck", "lint", "test"]
    },
    "//#openapi": {
      "inputs": [
        "api/atlas/**/*.py",
        "api/pyproject.toml",
        "api/uv.lock"
      ],
      "outputs": ["openapi/atlas.openapi.json", "mintlify/openapi/atlas.openapi.json"]
    },
    "//#api:test": {
      "dependsOn": ["//#openapi"],
      "inputs": [
        "api/**",
        "openapi/atlas.openapi.json"
      ]
    },
    "//#contract:test": {
      "dependsOn": ["//#openapi"],
      "inputs": [
        "api/**",
        "openapi/atlas.openapi.json"
      ]
    },
    "//#compose:validate": {
      "inputs": [
        "compose.yaml",
        ".env.production.example",
        ".env.example",
        "deploy/Caddyfile"
      ]
    },
    "//#secrets:scan": {
      "inputs": [
        ".secrets.baseline",
        ".env.example",
        ".env.production.example",
        "api/.env.example",
        "app/.env.example",
        "api/uv.lock",
        "package.json",
        ".githooks/pre-push"
      ]
    },
    "//#e2e:api": {
      "inputs": [
        "api/**",
        "openapi/atlas.openapi.json"
      ],
      "env": [
        "ANTHROPIC_API_KEY",
        "ATLAS_AUTH_API_KEY_INTROSPECTION_URL",
        "ATLAS_AUTH_INTERNAL_SECRET",
        "CORS_ORIGINS",
        "DATABASE_URL",
        "ENABLE_API_DOCS_UI",
        "ENABLE_OPENAPI_SPEC",
        "ENVIRONMENT",
        "LOG_LEVEL",
        "PORT",
        "SEARCH_API_KEY"
      ],
      "persistent": true
    },
    "//#prod:verify": {
      "dependsOn": [
        "//#api:test",
        "//#contract:test",
        "//#compose:validate",
        "//#secrets:scan",
        "app#api-client",
        "app#openapi:lint",
        "app#quality",
        "app#test",
        "app#test:e2e",
        "app#build"
      ]
    }
  }
}
