# ============================================
# The Atlas - Production Environment Configuration
# ============================================

# Public routing
ATLAS_PUBLIC_URL=https://atlas.example.com
# Do not set ATLAS_DEPLOY_MODE in production (only set to "local" for local dev).

# OAuth audience claim — identifies the resource server that tokens are issued for.
# Set to the API's public URL. Keep separate from ATLAS_PUBLIC_URL even if they
# share the same value today.
ATLAS_API_AUDIENCE=https://api.atlas.example.com

# Backend runtime
ENVIRONMENT=production
LOG_LEVEL=info
ENABLE_OPENAPI_SPEC=true
ENABLE_API_DOCS_UI=true
DATABASE_URL=sqlite:///data/atlas.db
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
SEARCH_API_KEY=
ATLAS_AUTH_API_KEY_INTROSPECTION_URL=http://atlas-web:3000/api/auth/internal/api-key
ATLAS_AUTH_DB_PATH=/app/data/auth/atlas-auth.sqlite
ATLAS_AUTH_INTERNAL_SECRET=replace-with-a-long-random-secret
ATLAS_AUTH_ALLOWED_EMAILS=
ATLAS_EMAIL_PROVIDER=resend
ATLAS_EMAIL_FROM=Atlas <noreply@atlas-mail.example.com>
ATLAS_EMAIL_CAPTURE_URL=replace-only-if-you-switch-to-the-capture-provider
ATLAS_EMAIL_RESEND_API_KEY=replace-with-your-resend-api-key

# CORS
# Replace with your real Vercel and/or public app origins.
CORS_ORIGINS=["https://atlas.example.com"]
