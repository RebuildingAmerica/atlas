# ============================================
# The Atlas - Production Environment Configuration
# ============================================
# For Cloud Run deployment, these are set as env vars via the deploy workflow.
# This file documents what's needed.

# Public routing
ATLAS_PUBLIC_URL=https://atlas.rebuildingus.org
# Mintlify deployment origin used by Vercel to proxy atlas.rebuildingus.org/docs
ATLAS_DOCS_URL=https://your-subdomain.mintlify.dev
# Do not set ATLAS_DEPLOY_MODE in production (only set to "local" for local dev).

# OAuth audience claim — identifies the resource server that tokens are issued for.
ATLAS_API_AUDIENCE=https://atlas.rebuildingus.org

# Backend runtime
ENVIRONMENT=production
LOG_LEVEL=info
ENABLE_OPENAPI_SPEC=true
ENABLE_API_DOCS_UI=false

# Database — Neon PostgreSQL (production) or sqlite:///data/atlas.db (local)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/atlas?sslmode=require

# API keys
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
SEARCH_API_KEY=

# Auth
ATLAS_AUTH_API_KEY_INTROSPECTION_URL=http://atlas-web:3000/api/auth/internal/api-key
ATLAS_AUTH_MEMBERSHIP_URL=http://atlas-web:3000
ATLAS_AUTH_INTERNAL_SECRET=replace-with-a-long-random-secret
ATLAS_AUTH_ALLOWED_EMAILS=

# Email
ATLAS_EMAIL_PROVIDER=resend
ATLAS_EMAIL_FROM=Atlas <noreply@atlas.rebuildingus.org>
ATLAS_EMAIL_RESEND_API_KEY=replace-with-your-resend-api-key

# Service routing (Cloud Run)
# The internal Cloud Run URL of the atlas-api service.
# For hosted app deployments (for example Vercel), set this to the public Atlas
# API origin the app should proxy browser-visible `/api/*` requests to.
ATLAS_SERVER_API_PROXY_TARGET=https://atlas-api-xxxxxxxxxx-uc.a.run.app

# CORS
CORS_ORIGINS=["https://atlas.rebuildingus.org"]
