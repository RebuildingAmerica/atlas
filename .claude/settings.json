{
  "permissions": {
    "allow": [
      "Bash(git restore --staged*)",
      "Bash(*git restore --staged*)"
    ],
    "deny": [
      "Bash(git commit --no-verify*)",
      "Bash(git push --no-verify*)",
      "Bash(*--no-verify*)",
      "Bash(git stash*)",
      "Bash(git reset*)",
      "Bash(git checkout -- *)",
      "Bash(git clean*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git rebase*)",
      "Bash(git cherry-pick*)",
      "Bash(git merge*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(*git stash*)",
      "Bash(*git reset*)",
      "Bash(*&& git stash*)",
      "Bash(*; git stash*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q -- '--no-verify' && echo '{\"decision\":\"block\",\"reason\":\"--no-verify is banned. Fix the underlying issue instead of skipping hooks.\"}' && exit 1 || true"
          }
        ]
      }
    ]
  }
}
