{
  "name": "atlas",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.3.0 <25"
  },
  "scripts": {
    "secrets:update-baseline": "sh ./scripts/secrets-update-baseline.sh",
    "secrets:scan": "sh ./scripts/secrets-scan.sh",
    "openapi": "sh ./scripts/openapi-export.sh",
    "api:test": "sh ./scripts/api-test.sh",
    "quality": "turbo run typecheck lint test",
    "test:coverage": "turbo run //#api:test app#test:coverage",
    "test:e2e": "turbo run app#test:e2e",
    "test:e2e:headed": "turbo run app#test:e2e:headed",
    "contract:test": "sh ./scripts/contract-test.sh",
    "compose:validate": "sh ./scripts/compose-validate.sh",
    "e2e:api": "uv --directory ./api run python -m atlas.platform.e2e_server",
    "prod:verify": "printf 'Atlas production verification graph completed\\n'",
    "verify": "turbo run //#prod:verify",
    "bootstrap": "tsx scripts/bootstrap/cold-start.ts",
    "doctor": "tsx scripts/bootstrap/cold-start.ts --doctor"
  },
  "devDependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.0",
    "stripe": "^18.0.0",
    "tsx": "^4.19.0",
    "turbo": "^2.9.6"
  }
}
